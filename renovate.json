{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": ["tekton"],
  "assigneesFromCodeOwners": true,
  "automergeStrategy": "auto",
  "automergeType": "pr",
  "prConcurrentLimit": 5,
  "ignoreTests": false,
  "rebaseLabel": "needs-rebase",
  "rebaseWhen": "behind-base-branch",
  "recreateWhen": "always",
  "commitMessageSuffix": "[{{baseBranch}}]",
  "packageRules": [
    {
      "matchManagers": ["tekton"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all minor tekton dependencies",
      "automerge": true,
      "description": "Group all minor tekton dependencies",
      "addLabels": ["jira/valid-reference", "lgtm", "approved"]
    }
  ]
}
